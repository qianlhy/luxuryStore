<view class="settings-container"><view class="user-profile"><view class="profile-header">个人资料</view><block wx:if="{{!editMode}}"><view class="profile-content"><view class="profile-item avatar-item"><text class="item-label">头像</text><view class="item-content"><image class="user-avatar" src="{{avatarUrl}}" mode="aspectFill"></image></view><view data-event-opts="{{[['tap',[['enterEditMode',['$event']]]]]}}" class="item-action" bindtap="__e"><text>编辑</text><text class="arrow">></text></view></view><view class="profile-item"><text class="item-label">昵称</text><view class="item-content">{{nickName||'未设置'}}</view></view></view></block><block wx:if="{{editMode}}"><view class="profile-edit"><view class="edit-item"><text class="edit-label">头像</text><view class="edit-avatar-wrapper"><image class="edit-preview-avatar" src="{{avatarUrl}}" mode="aspectFill"></image><button class="avatar-button" open-type="chooseAvatar" data-event-opts="{{[['chooseavatar',[['chooseAvatar',['$event']]]]]}}" bindchooseavatar="__e"></button></view></view><view class="edit-item"><text class="edit-label">昵称</text><input class="edit-input" type="nickname" placeholder="请输入昵称" maxlength="20" data-event-opts="{{[['input',[['inputNickName',['$event']]]],['change',[['onNicknameChange',['$event']]]]]}}" value="{{nickName}}" bindinput="__e" bindchange="__e"/></view><view class="edit-actions"><view data-event-opts="{{[['tap',[['cancelEdit',['$event']]]]]}}" class="btn cancel" bindtap="__e">取消</view><view data-event-opts="{{[['tap',[['saveUserInfo',['$event']]]]]}}" class="btn save" bindtap="__e">保存</view></view></view></block><block wx:if="{{!isLogin&&!editMode}}"><view class="not-login"><button data-event-opts="{{[['tap',[['goToLogin',['$event']]]]]}}" class="login-btn" bindtap="__e">登录/注册</button></view></block></view><view class="system-settings"><view class="settings-header">系统设置</view><view data-event-opts="{{[['tap',[['clearCache',['$event']]]]]}}" class="settings-item" bindtap="__e"><text class="item-label">清除缓存</text><view class="item-content">{{cacheSize}}</view><text class="arrow">></text></view><view data-event-opts="{{[['tap',[['aboutUs',['$event']]]]]}}" class="settings-item" bindtap="__e"><text class="item-label">关于我们</text><text class="arrow">></text></view><view class="settings-item"><text class="item-label">当前版本</text><view class="item-content">{{version}}</view></view></view><view class="agreement"><navigator class="agreement-link" url="/pages/agreement/privacy">隐私政策</navigator><text class="divider">|</text><navigator class="agreement-link" url="/pages/agreement/user">用户协议</navigator></view></view>