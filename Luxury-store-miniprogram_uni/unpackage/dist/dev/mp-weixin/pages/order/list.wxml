<view class="order-list-container"><view class="tabs"><block wx:for="{{tabs}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="{{['tab-item '+(activeTab===item.id?'active':'')]}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['switchTab',['$event']]]]]}}" bindtap="__e"><text>{{item.name}}</text><block wx:if="{{activeTab===item.id}}"><view class="tab-line"></view></block></view></block></view><scroll-view class="order-scroll" scroll-y="{{true}}" enable-back-to-top="{{true}}" data-event-opts="{{[['scrolltolower',[['loadMoreOrders',['$event']]]]]}}" bindscrolltolower="__e"><block wx:if="{{isLoading}}"><view class="loading-container"><view class="loading"><image class="loading-icon" src="/static/images/icons/loading.png" mode="aspectFit"></image><text>加载中...</text></view></view></block><block wx:if="{{!isLoading&&isEmpty}}"><view class="empty-container"><image class="empty-icon" src="/static/images/icons/empty.png" mode="aspectFit"></image><text>暂无订单</text></view></block><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="order-item"><view class="order-header" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['goToOrderDetail',['$event']]]]]}}" bindtap="__e"><view class="order-number">{{"订单号："+item.$orig.id}}</view><view class="{{['order-status '+(item.$orig.statusText==='已取消'?'cancelled':'')]}}">{{item.$orig.statusText}}</view></view><view class="order-goods" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['goToOrderDetail',['$event']]]]]}}" bindtap="__e"><block wx:for="{{item.$orig.items}}" wx:for-item="goods" wx:for-index="index1" wx:key="index1"><view class="goods-item"><image class="goods-image" src="{{goods.productImage}}" mode="aspectFill"></image><view class="goods-info"><view class="goods-name text-ellipsis">{{goods.productName}}</view><view class="goods-price">{{"¥"+goods.price+" x "+goods.count}}</view></view></view></block></view><view class="order-footer"><view class="order-total"><text>{{"共"+item.g0+"件商品"}}</text><text>{{"合计：¥"+item.$orig.actualPayment}}</text></view><view class="order-actions"><block wx:if="{{item.$orig.statusText==='待付款'}}"><block><view class="action-btn outline" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['cancelOrder',['$event']]]]]}}" bindtap="__e">取消订单</view><view class="action-btn primary" data-id="{{item.$orig.id}}" data-amount="{{item.$orig.actualPayment}}" data-event-opts="{{[['tap',[['goToPay',['$event']]]]]}}" bindtap="__e">去支付</view></block></block><block wx:else><block wx:if="{{item.$orig.statusText==='待发货'}}"><block><view data-event-opts="{{[['tap',[['checkLogistics',['$event']]]]]}}" class="action-btn outline" bindtap="__e">查看物流</view></block></block><block wx:else><block wx:if="{{item.$orig.statusText==='待收货'}}"><block><view data-event-opts="{{[['tap',[['checkLogistics',['$event']]]]]}}" class="action-btn outline" bindtap="__e">查看物流</view><view class="action-btn primary" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['confirmReceipt',['$event']]]]]}}" bindtap="__e">确认收货</view></block></block><block wx:else><block wx:if="{{item.$orig.statusText==='已完成'}}"><block><view data-event-opts="{{[['tap',[['checkLogistics',['$event']]]]]}}" class="action-btn outline" bindtap="__e">查看物流</view></block></block><block wx:else><block wx:if="{{item.$orig.statusText==='已取消'}}"><block><view class="action-btn outline" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['goToOrderDetail',['$event']]]]]}}" bindtap="__e">订单详情</view></block></block></block></block></block></block></view></view></view></block></scroll-view></view>