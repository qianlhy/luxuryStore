<view class="order-detail-container"><view class="address-section"><view class="section-title">收货地址</view><view class="address-content"><view class="name-phone"><text class="name">{{orderInfo.order.receiverName}}</text><text class="phone">{{orderInfo.order.receiverPhone}}</text></view><view class="address-detail">{{orderInfo.order.province+orderInfo.order.city+orderInfo.order.district+orderInfo.order.address}}</view></view></view><view class="goods-section"><view class="section-title">商品信息</view><view class="goods-list"><block wx:for="{{orderInfo.items}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="goods-item"><image class="goods-image" src="{{item.productImage}}" mode="aspectFill"></image><view class="goods-info"><view class="goods-name">{{item.productName}}</view><view class="goods-price-count"><text class="goods-price">{{"¥"+item.price}}</text><text class="goods-count">{{"x"+item.count}}</text></view></view></view></block></view></view><view class="order-info-section"><view class="section-title">订单信息</view><view class="order-info-item"><text class="label">订单编号</text><view class="value-copy"><text class="value">{{orderId}}</text><view data-event-opts="{{[['tap',[['copyOrderId',['$event']]]]]}}" class="copy-btn" bindtap="__e">复制</view></view></view><view class="order-info-item"><text class="label">创建时间</text><text class="value">{{orderInfo.order.createTime}}</text></view><view class="order-info-item"><text class="label">支付方式</text><text class="value">{{orderInfo.order.paymentMethod==='online'?'在线支付':'货到付款'}}</text></view><block wx:if="{{orderInfo.order.remark}}"><view class="order-info-item"><text class="label">订单备注</text><text class="value">{{orderInfo.order.remark}}</text></view></block></view><view class="amount-section"><view class="amount-item"><text class="label">商品总额</text><text class="value">{{"¥"+orderInfo.order.totalPrice}}</text></view><view class="amount-item"><text class="label">运费</text><text class="value">{{"¥"+orderInfo.order.freight}}</text></view><view class="amount-item total"><text class="label">实付款</text><text class="value">{{"¥"+orderInfo.order.actualPayment}}</text></view></view><view class="footer"><block wx:if="{{orderInfo.status==='待付款'}}"><block><button data-event-opts="{{[['tap',[['cancelOrder',['$event']]]]]}}" class="btn cancel" bindtap="__e">取消订单</button><button data-event-opts="{{[['tap',[['goToPay',['$event']]]]]}}" class="btn primary" bindtap="__e">去支付</button></block></block><block wx:else><block wx:if="{{orderInfo.status==='待发货'}}"><block><button data-event-opts="{{[['tap',[['contactService',['$event']]]]]}}" class="btn" bindtap="__e">联系客服</button></block></block><block wx:else><block wx:if="{{orderInfo.status==='待收货'}}"><block><button data-event-opts="{{[['tap',[['checkLogistics',['$event']]]]]}}" class="btn" bindtap="__e">查看物流</button><button data-event-opts="{{[['tap',[['confirmReceipt',['$event']]]]]}}" class="btn primary" bindtap="__e">确认收货</button></block></block><block wx:else><block wx:if="{{orderInfo.status==='已完成'}}"><block><button data-event-opts="{{[['tap',[['contactService',['$event']]]]]}}" class="btn" bindtap="__e">联系客服</button></block></block></block></block></block></view></view>