<view class="order-container"><view class="address-section"><block wx:if="{{!hasAddress}}"><view data-event-opts="{{[['tap',[['addAddress',['$event']]]]]}}" class="address-empty" bindtap="__e"><view class="add-address"><image class="add-icon" src="/static/images/icons/add-address.png"></image><text>添加收货地址</text></view><view class="arrow">></view></view></block><block wx:else><view data-event-opts="{{[['tap',[['selectAddress',['$event']]]]]}}" class="address-info" bindtap="__e"><view class="address-detail"><view class="name-phone"><text class="name">{{selectedAddress.name}}</text><text class="phone">{{selectedAddress.phone}}</text></view><view class="address"><block wx:if="{{selectedAddress.isDefault}}"><text class="default-tag">默认</text></block><text class="address-text">{{selectedAddress.province+selectedAddress.city+selectedAddress.district+selectedAddress.address}}</text></view></view><view class="arrow">></view></view></block></view><view class="goods-section"><view class="section-title">商品清单</view><view class="goods-list"><block wx:for="{{orderItems}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="goods-item"><image class="goods-image" src="{{item.image}}" mode="aspectFill"></image><view class="goods-info"><text class="goods-name text-ellipsis">{{item.name}}</text><view class="goods-price-box"><text class="price">{{"¥"+item.price}}</text><text class="count">{{"x"+item.count}}</text></view></view></view></block></view></view><view class="payment-section"><view class="section-title">支付方式</view><view class="payment-options"><view class="{{['payment-option '+(paymentMethod==='online'?'selected':'')]}}" data-method="online" data-event-opts="{{[['tap',[['switchPaymentMethod',['$event']]]]]}}" bindtap="__e"><image class="payment-icon" src="/static/images/icons/online-pay.png"></image><text class="payment-name">在线支付</text><view class="radio-box"><view class="{{['radio '+(paymentMethod==='online'?'selected':'')]}}"></view></view></view><view class="{{['payment-option '+(paymentMethod==='delivery'?'selected':'')]}}" data-method="delivery" data-event-opts="{{[['tap',[['switchPaymentMethod',['$event']]]]]}}" bindtap="__e"><image class="payment-icon" src="/static/images/icons/delivery-pay.png"></image><text class="payment-name">货到付款</text><view class="radio-box"><view class="{{['radio '+(paymentMethod==='delivery'?'selected':'')]}}"></view></view></view></view></view><view class="remark-section"><view class="section-title">订单备注</view><textarea class="remark-input" placeholder="请输入订单备注（选填）" maxlength="100" data-event-opts="{{[['input',[['inputRemark',['$event']]]]]}}" value="{{remark}}" bindinput="__e"></textarea></view><view class="amount-section"><view class="amount-item"><text class="amount-label">商品金额</text><text class="amount-value">{{"¥"+totalPrice}}</text></view><view class="amount-item"><text class="amount-label">运费</text><text class="amount-value">{{"¥"+freight}}</text></view><view class="divider"></view><view class="amount-item total"><text class="amount-label">实付款</text><text class="amount-value price">{{"¥"+actualPayment}}</text></view></view><view class="footer"><view class="total-info"><text class="total-label">合计：</text><text class="total-price">{{"¥"+actualPayment}}</text></view><button class="{{['submit-btn '+(isLoading?'loading':'')]}}" disabled="{{isLoading}}" data-event-opts="{{[['tap',[['submitOrder',['$event']]]]]}}" bindtap="__e">{{''+(isLoading?'提交中...':'提交订单')+''}}</button></view></view>