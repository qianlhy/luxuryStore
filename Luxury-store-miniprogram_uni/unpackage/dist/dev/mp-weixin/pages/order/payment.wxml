<view class="payment-container"><view class="payment-header"><view class="amount">{{"￥"+amount}}</view><view class="order-id">{{"订单号："+orderId}}</view><view class="countdown">{{"支付剩余时间："+countdownFormatted}}</view></view><view class="payment-methods"><view class="section-title">选择支付方式</view><view class="{{['method-item '+(paymentMethod==='wechat'?'selected':'')]}}" data-method="wechat" data-event-opts="{{[['tap',[['switchPaymentMethod',['$event']]]]]}}" bindtap="__e"><view class="method-icon wechat-icon"></view><view class="method-name">微信支付</view><block wx:if="{{paymentMethod==='wechat'}}"><view class="method-check">✓</view></block></view><view class="{{['method-item '+(paymentMethod==='alipay'?'selected':'')]}}" data-method="alipay" data-event-opts="{{[['tap',[['switchPaymentMethod',['$event']]]]]}}" bindtap="__e"><view class="method-icon alipay-icon"></view><view class="method-name">支付宝</view><block wx:if="{{paymentMethod==='alipay'}}"><view class="method-check">✓</view></block></view><view class="{{['method-item '+(paymentMethod==='card'?'selected':'')]}}" data-method="card" data-event-opts="{{[['tap',[['switchPaymentMethod',['$event']]]]]}}" bindtap="__e"><view class="method-icon card-icon"></view><view class="method-name">银行卡支付</view><block wx:if="{{paymentMethod==='card'}}"><view class="method-check">✓</view></block></view></view><view class="payment-footer"><button data-event-opts="{{[['tap',[['cancelPayment',['$event']]]]]}}" class="cancel-btn" bindtap="__e">取消支付</button><button class="{{['pay-btn '+(isLoading?'loading':'')]}}" disabled="{{isLoading}}" data-event-opts="{{[['tap',[['payNow',['$event']]]]]}}" bindtap="__e">{{''+(isLoading?'支付中...':'立即支付')+''}}</button></view></view>