<view class="collection-container"><block wx:if="{{!isLogin}}"><view class="not-login"><empty-state vue-id="25461d80-1" icon="favorite" text="登录后查看收藏的商品" bind:__l="__l" vue-slots="{{['default']}}"><button data-event-opts="{{[['tap',[['goToLogin',['$event']]]]]}}" class="login-btn" bindtap="__e">去登录</button></empty-state></view></block><block wx:else><block><block wx:if="{{isLoading}}"><loading-state vue-id="25461d80-2" bind:__l="__l"></loading-state></block><block wx:else><block wx:if="{{isEmpty}}"><view class="empty-collection"><empty-state vue-id="25461d80-3" icon="favorite" text="您还没有收藏任何商品" sub-text="收藏心仪好物，随时查看" bind:__l="__l" vue-slots="{{['default']}}"><navigator class="go-shopping" url="/pages/index/index" open-type="switchTab">去逛逛</navigator></empty-state></view></block><block wx:else><view class="collection-list"><block wx:for="{{favorites}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="collection-item" data-id="{{item.id}}" data-event-opts="{{[['tap',[['viewProductDetail',['$event']]]]]}}" bindtap="__e"><view class="product-card"><image class="product-image" src="{{item.image}}" mode="aspectFill"></image><view class="product-info"><view class="product-name">{{item.name}}</view><view class="product-price"><text class="current-price">{{"¥"+item.price}}</text><block wx:if="{{item.originalPrice}}"><text class="original-price">{{"¥"+item.originalPrice}}</text></block></view><view class="product-sales">{{"销量 "+item.sales}}</view><view class="product-actions"><view class="action-btn cancel" data-id="{{item.id}}" data-event-opts="{{[['tap',[['cancelFavorite',['$event']]]]]}}" catchtap="__e">取消收藏</view><view class="action-btn add-cart" data-id="{{item.id}}" data-event-opts="{{[['tap',[['addToCart',['$event']]]]]}}" catchtap="__e">加入购物车</view></view></view></view></view></block></view></block></block></block></block></view>