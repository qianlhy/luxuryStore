<view class="user-container"><view class="user-header"><view class="header-top"><block wx:if="{{isLogin}}"><view data-event-opts="{{[['tap',[['goToSettings',['$event']]]]]}}" class="user-info-row" bindtap="__e"><text class="user-nickname">{{userInfo.nickName||userInfo.nickname||'微信用户'}}</text><text class="settings-icon">⚙</text></view></block><block wx:else><view data-event-opts="{{[['tap',[['goToLogin',['$event']]]]]}}" class="user-info-row" bindtap="__e"><text class="login-text">登录/注册</text><text class="settings-icon">⚙</text></view></block></view><view data-event-opts="{{[['tap',[['goToPoints',['$event']]]]]}}" class="points-card" bindtap="__e"><view class="points-left"><text class="points-tip">下单获赠积分，积分兑换更优惠</text></view><view class="points-right"><text class="points-num">{{points}}</text><text class="points-label">我的积分</text></view></view></view><block wx:if="{{!isLogin}}"><view class="login-prompt"><view class="login-icon"></view><text class="login-prompt-text">暂未登录</text><view data-event-opts="{{[['tap',[['goToLogin',['$event']]]]]}}" class="login-outline-btn" bindtap="__e">去登录</view></view></block><block wx:if="{{isLogin}}"><view class="quick-links"><view class="quick-item" data-url="/pages/points/points" data-event-opts="{{[['tap',[['navigateTo',['$event']]]]]}}" bindtap="__e"><text class="quick-icon">📋</text><text>权益列表</text></view><view class="quick-item" data-url="/pages/collection/collection" data-event-opts="{{[['tap',[['navigateTo',['$event']]]]]}}" bindtap="__e"><text class="quick-icon">⭐</text><text>收藏</text></view><view class="quick-item" data-url="/pages/footprint/footprint" data-event-opts="{{[['tap',[['navigateTo',['$event']]]]]}}" bindtap="__e"><text class="quick-icon">👣</text><text>足迹</text></view></view></block><block wx:if="{{isLogin}}"><view class="order-section"><view data-event-opts="{{[['tap',[['viewAllOrders',['$event']]]]]}}" class="section-header" bindtap="__e"><text class="section-title">我的订单</text><text class="section-more">全部订单 ></text></view><view class="order-types"><view class="order-type" data-status="待付款" data-event-opts="{{[['tap',[['viewOrdersByStatus',['$event']]]]]}}" bindtap="__e"><text class="order-emoji">💳</text><text>待付款</text><block wx:if="{{orderStats.unpaid>0}}"><view class="order-badge">{{orderStats.unpaid}}</view></block></view><view class="order-type" data-status="待发货" data-event-opts="{{[['tap',[['viewOrdersByStatus',['$event']]]]]}}" bindtap="__e"><text class="order-emoji">📦</text><text>待发货</text></view><view class="order-type" data-status="待收货" data-event-opts="{{[['tap',[['viewOrdersByStatus',['$event']]]]]}}" bindtap="__e"><text class="order-emoji">🚚</text><text>待收货</text></view><view class="order-type" data-status="已完成" data-event-opts="{{[['tap',[['viewOrdersByStatus',['$event']]]]]}}" bindtap="__e"><text class="order-emoji">✅</text><text>已完成</text></view></view></view></block><view class="features"><text class="features-title">工具与服务</text><view class="feature-item" data-url="/pages/share/list" data-event-opts="{{[['tap',[['navigateTo',['$event']]]]]}}" bindtap="__e"><text class="feature-emoji">🔗</text><text>分享记录</text><text class="arrow">></text></view><view class="feature-item" data-url="/pages/address/list" data-event-opts="{{[['tap',[['navigateTo',['$event']]]]]}}" bindtap="__e"><text class="feature-emoji">📍</text><text>收货地址</text><text class="arrow">></text></view><view data-event-opts="{{[['tap',[['contactService',['$event']]]]]}}" class="feature-item" bindtap="__e"><text class="feature-emoji">🎧</text><text>联系客服</text><text class="arrow">></text></view><view class="feature-item" data-url="/pages/settings/settings" data-event-opts="{{[['tap',[['navigateTo',['$event']]]]]}}" bindtap="__e"><text class="feature-emoji">⚙</text><text>设置中心</text><text class="arrow">></text></view><block wx:if="{{isLogin}}"><view data-event-opts="{{[['tap',[['logout',['$event']]]]]}}" class="feature-item" bindtap="__e"><text class="feature-emoji">🚪</text><text>退出登录</text><text class="arrow">></text></view></block></view><view class="version-info"><text>白白叶叶奢侈品 v2.0.0</text></view></view>