<view class="share-container"><block wx:if="{{$root.g0===0}}"><view class="empty"><text>暂无分享记录</text></view></block><block wx:for="{{list}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="share-item"><view class="share-header"><text class="share-type">{{item.shareTypeName}}</text><text class="share-time">{{item.createTime}}</text></view><view class="share-products">{{item.productNames}}</view><view class="share-footer"><text class="share-price">{{"合计 ¥"+item.totalPrice}}</text><text class="share-views">{{"查看 "+item.viewCount+" 次"}}</text></view></view></block></view>