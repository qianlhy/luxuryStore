<view class="share-container"><block wx:if="{{loading}}"><loading-state vue-id="7bda7adf-1" bind:__l="__l"></loading-state></block><block wx:else><block wx:if="{{$root.g0===0}}"><empty-state vue-id="7bda7adf-2" text="暂无分享记录" sub-text="在购物车分享好物给好友吧" bind:__l="__l"></empty-state></block><block wx:else><block><block wx:for="{{list}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="share-item"><view class="share-header"><text class="share-type">{{item.shareTypeName}}</text><text class="share-time">{{item.createTime}}</text></view><view class="share-products">{{item.productNames}}</view><view class="share-footer"><text class="share-price">{{"合计 ¥"+item.totalPrice}}</text><text class="share-views">{{"查看 "+item.viewCount+" 次"}}</text></view></view></block></block></block></block></view>