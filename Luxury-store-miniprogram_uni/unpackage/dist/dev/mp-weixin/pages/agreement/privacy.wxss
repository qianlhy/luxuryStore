
.agreement-page {
    min-height: 100vh;
    background-color: #fff;
    padding: 40rpx 30rpx 80rpx;
}
.agreement-title {
    font-size: 40rpx;
    font-weight: bold;
    color: #1a1a1a;
    text-align: center;
}
.agreement-update {
    font-size: 24rpx;
    color: #999;
    text-align: center;
    margin: 16rpx 0 40rpx;
}
.agreement-section {
    margin-bottom: 36rpx;
}
.section-title {
    font-size: 30rpx;
    font-weight: bold;
    color: #1a1a1a;
    margin-bottom: 16rpx;
}
.section-text {
    font-size: 27rpx;
    color: #555;
    line-height: 1.8;
    margin-bottom: 10rpx;
}
.agreement-footer {
    margin-top: 40rpx;
    font-size: 26rpx;
    color: #999;
    line-height: 1.8;
}

