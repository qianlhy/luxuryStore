<view class="search-container"><view class="search-header"><view class="search-input-box"><icon class="search-icon" type="search" size="16"></icon><input class="search-input" placeholder="搜索商品" confirm-type="search" focus="{{true}}" data-event-opts="{{[['input',[['inputKeyword',['$event']]]],['confirm',[['onSearch',['$event']]]]]}}" value="{{keyword}}" bindinput="__e" bindconfirm="__e"/><block wx:if="{{keyword}}"><view data-event-opts="{{[['tap',[['clearKeyword',['$event']]]]]}}" class="clear-icon" bindtap="__e"><icon type="clear" size="16"></icon></view></block></view><view data-event-opts="{{[['tap',[['onSearch',['$event']]]]]}}" class="search-btn" bindtap="__e">搜索</view></view><block wx:if="{{showHistory}}"><view class="search-history"><block wx:if="{{$root.g0>0}}"><view class="history-section"><view class="section-header"><text class="section-title">搜索历史</text><view data-event-opts="{{[['tap',[['clearSearchHistory',['$event']]]]]}}" class="clear-history" bindtap="__e"><icon type="clear" size="16"></icon></view></view><view class="history-list"><block wx:for="{{searchHistory}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="history-item" data-keyword="{{item}}" data-event-opts="{{[['tap',[['tapSearchItem',['$event']]]]]}}" bindtap="__e">{{''+item+''}}</view></block></view></view></block><view class="hot-section"><view class="section-header"><text class="section-title">热门搜索</text></view><view class="hot-list"><block wx:for="{{hotSearches}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="hot-item" data-keyword="{{item}}" data-event-opts="{{[['tap',[['tapSearchItem',['$event']]]]]}}" bindtap="__e">{{''+item+''}}</view></block></view></view></view></block><block wx:if="{{isSearching}}"><view class="search-results"><block wx:if="{{isLoading}}"><view class="loading"><image class="loading-icon" src="/static/images/icons/loading.png" mode="aspectFit"></image><text>搜索中...</text></view></block><block wx:else><block wx:if="{{isEmpty}}"><view class="empty-result"><image class="empty-icon" src="/static/images/icons/empty.png" mode="aspectFit"></image><view class="empty-tip">未找到相关商品</view><view class="suggestion">换个关键词试试吧</view></view></block><block wx:else><view class="result-list"><block wx:for="{{searchResults}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="result-item" data-id="{{item.id}}" data-event-opts="{{[['tap',[['viewProductDetail',['$event']]]]]}}" bindtap="__e"><image class="product-image" src="{{item.image}}" mode="aspectFill"></image><view class="product-info"><view class="product-name">{{item.name}}</view><view class="product-desc">{{item.description}}</view><view class="product-price-box"><text class="price">{{"¥"+item.price}}</text><block wx:if="{{item.originalPrice}}"><text class="price-original">{{"¥"+item.originalPrice}}</text></block></view><view class="product-sales">{{"已售"+item.sales+"件"}}</view></view><view class="add-cart-btn" data-id="{{item.id}}" data-event-opts="{{[['tap',[['addToCart',['$event']]]]]}}" catchtap="__e">+</view></view></block></view></block></block></view></block></view>