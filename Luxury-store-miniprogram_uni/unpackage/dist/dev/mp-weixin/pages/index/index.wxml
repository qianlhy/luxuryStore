<view><view class="index-container"><view class="top-header"><view class="logo-area"><view class="brand-badge">BY</view><text class="logo-text">白白叶叶</text></view><view data-event-opts="{{[['tap',[['onTapSearch',['$event']]]]]}}" class="search-input-box" bindtap="__e"><view class="search-icon"></view><block wx:if="{{$root.g0}}"><swiper class="search-swiper" vertical="{{true}}" autoplay="{{true}}" circular="{{true}}" interval="{{2500}}" duration="{{400}}"><block wx:for="{{hotKeywords}}" wx:for-item="kw" wx:for-index="i" wx:key="i"><swiper-item><text class="search-placeholder">{{kw}}</text></swiper-item></block></swiper></block><block wx:else><text class="search-placeholder">请输入关键词</text></block></view></view><view class="endorse-bar"><view class="endorse-item"><text class="endorse-icon">🛡️</text><text class="endorse-text">正品保障</text></view><view class="endorse-divider"></view><view class="endorse-item"><text class="endorse-icon">🔍</text><text class="endorse-text">中检鉴定</text></view><view class="endorse-divider"></view><view class="endorse-item"><text class="endorse-icon">💎</text><text class="endorse-text">假一赔三</text></view></view><swiper class="banner" indicator-dots="{{true}}" autoplay="{{true}}" interval="4000" duration="500" circular="{{true}}" indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#E14C82"><block wx:for="{{banners}}" wx:for-item="item" wx:for-index="index" wx:key="index"><swiper-item><image class="banner-image" src="{{item.image}}" mode="aspectFill"></image><view class="banner-overlay"><text class="banner-title">{{item.title}}</text><text class="banner-sub">{{item.subtitle}}</text></view></swiper-item></block></swiper><view class="category-tiles"><block wx:for="{{categoryTiles}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="tile-item" data-id="{{item.id}}" data-event-opts="{{[['tap',[['onTapCategory',['$event']]]]]}}" bindtap="__e"><image class="tile-img" src="{{item.image}}" mode="aspectFill"></image><text class="tile-name">{{item.name}}</text></view></block></view><view class="brand-section"><scroll-view class="brand-scroll" scroll-x="{{true}}"><block wx:for="{{brands}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="brand-circle" data-id="{{1}}" data-event-opts="{{[['tap',[['onTapCategory',['$event']]]]]}}" bindtap="__e"><image class="brand-logo" src="{{item.coverImage}}" mode="aspectFill"></image><text class="brand-name">{{item.name}}</text></view></block></scroll-view></view><view data-event-opts="{{[['tap',[['onTapBargain',['$event']]]]]}}" class="bargain-bar" bindtap="__e"><view class="bargain-left"><text class="bargain-icon">🔥</text><view class="bargain-texts"><text class="bargain-title">捡漏专区</text><text class="bargain-sub">{{bargainText}}</text></view></view><text class="bargain-more">查看更多 ›</text></view><view class="entry-tiles"><view data-event-opts="{{[['tap',[['onTapHotList',['$event']]]]]}}" class="entry-tile" bindtap="__e"><image class="entry-tile-img" src="{{hotTileImage}}" mode="aspectFill"></image><view class="entry-tile-mask"><text class="entry-tile-title">爆款推荐</text><text class="entry-tile-arrow">好价精选 ›</text></view></view><view data-event-opts="{{[['tap',[['onTapStore',['$event']]]]]}}" class="entry-tile" bindtap="__e"><image class="entry-tile-img" src="{{storeTileImage}}" mode="aspectFill"></image><view class="entry-tile-mask"><text class="entry-tile-title">门店地址</text><text class="entry-tile-arrow">到店选购 ›</text></view></view></view><block wx:if="{{loading}}"><loading-state vue-id="8dd740cc-1" skeleton="{{true}}" count="{{3}}" bind:__l="__l"></loading-state></block><block wx:else><block wx:if="{{loadError}}"><view class="section"><empty-state vue-id="8dd740cc-2" text="加载失败" sub-text="网络似乎开小差了" bind:__l="__l" vue-slots="{{['default']}}"><button data-event-opts="{{[['tap',[['loadProducts',['$event']]]]]}}" class="retry-btn" bindtap="__e">点击重试</button></empty-state></view></block><block wx:else><block><block wx:if="{{$root.g1}}"><view class="section"><view class="section-header"><text class="section-title">最近上新</text><text data-event-opts="{{[['tap',[['onTapMore',['$event']]]]]}}" class="section-more" bindtap="__e">去看看 ></text></view><view class="product-list"><block wx:for="{{newProducts}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="product-item" data-id="{{item.id}}" data-event-opts="{{[['tap',[['onTapProduct',['$event']]]]]}}" bindtap="__e"><image class="product-image" src="{{item.image}}" mode="aspectFill" lazy-load="{{true}}"></image><view class="product-info"><text class="product-name text-ellipsis">{{item.name}}</text><view class="product-price-box"><text class="price">{{"¥"+item.price}}</text></view></view></view></block></view></view></block><block wx:if="{{!$root.g2}}"><view class="section"><empty-state vue-id="8dd740cc-3" text="暂无商品" sub-text="敬请期待更多好物" bind:__l="__l"></empty-state></view></block></block></block></block><block wx:if="{{showStorePopup}}"><view data-event-opts="{{[['tap',[['closeStore',['$event']]]]]}}" class="store-mask" bindtap="__e"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="store-popup" catchtap="__e"><view data-event-opts="{{[['tap',[['closeStore',['$event']]]]]}}" class="store-close" bindtap="__e">×</view><text class="store-title">门店地址</text><text class="store-address">{{storeAddress}}</text><view data-event-opts="{{[['tap',[['copyAddress',['$event']]]]]}}" class="store-copy-btn" bindtap="__e">复制地址</view></view></view></block></view><view data-event-opts="{{[['tap',[['contactService',['$event']]]]]}}" class="float-service" bindtap="__e"><text class="float-icon">🎧</text><text class="float-text">联系客服</text></view><block wx:if="{{showToast}}"><view class="toast-container"><view class="toast-content"><icon type="success" size="24"></icon><text>已加入购物车</text></view></view></block></view>