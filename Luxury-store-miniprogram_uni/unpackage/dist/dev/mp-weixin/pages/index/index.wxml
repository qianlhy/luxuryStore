<view><view class="index-container"><view class="top-header"><view class="logo-area"><text class="logo-text">名品汇</text></view><view data-event-opts="{{[['tap',[['onTapSearch',['$event']]]]]}}" class="search-input-box" bindtap="__e"><text class="search-icon">🔍</text><text class="search-placeholder">请输入关键词</text></view></view><scroll-view class="nav-tabs" scroll-x="{{true}}"><view class="nav-tab active">首页</view><block wx:for="{{categories}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="nav-tab" data-id="{{item.id}}" data-event-opts="{{[['tap',[['onTapCategory',['$event']]]]]}}" bindtap="__e">{{item.name}}</view></block></scroll-view><swiper class="banner" indicator-dots="{{true}}" autoplay="{{true}}" interval="4000" duration="500" circular="{{true}}" indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#C5A36A"><block wx:for="{{banners}}" wx:for-item="item" wx:for-index="index" wx:key="index"><swiper-item><image class="banner-image" src="{{item.image}}" mode="aspectFill"></image><view class="banner-overlay"><text class="banner-title">{{item.title}}</text><text class="banner-sub">{{item.subtitle}}</text></view></swiper-item></block></swiper><view class="category-tiles"><block wx:for="{{categoryTiles}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="tile-item" data-id="{{item.id}}" data-event-opts="{{[['tap',[['onTapCategory',['$event']]]]]}}" bindtap="__e"><image class="tile-img" src="{{item.image}}" mode="aspectFill"></image><text class="tile-name">{{item.name}}</text></view></block></view><view class="brand-section"><scroll-view class="brand-scroll" scroll-x="{{true}}"><block wx:for="{{brands}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="brand-circle" data-id="{{1}}" data-event-opts="{{[['tap',[['onTapCategory',['$event']]]]]}}" bindtap="__e"><image class="brand-logo" src="{{item.coverImage}}" mode="aspectFill"></image><text class="brand-name">{{item.name}}</text></view></block></scroll-view></view><view class="section"><view class="section-header"><text class="section-title">超值爆款</text><text class="section-sub">为您精选爆款</text></view><view class="hot-grid"><block wx:for="{{recommendProducts}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="hot-card" data-id="{{item.id}}" data-event-opts="{{[['tap',[['onTapProduct',['$event']]]]]}}" bindtap="__e"><image class="hot-img" src="{{item.image}}" mode="aspectFill"></image><view class="hot-info"><text class="hot-name text-ellipsis">{{item.name}}</text><text class="hot-price">{{"¥"+item.price}}</text></view></view></block></view></view><view class="section"><view class="section-header"><text class="section-title">最近上新</text><text data-event-opts="{{[['tap',[['onTapMore',['$event']]]]]}}" class="section-more" bindtap="__e">去看看 ></text></view><view class="product-list"><block wx:for="{{newProducts}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="product-item" data-id="{{item.id}}" data-event-opts="{{[['tap',[['onTapProduct',['$event']]]]]}}" bindtap="__e"><image class="product-image" src="{{item.image}}" mode="aspectFill"></image><view class="product-info"><text class="product-name text-ellipsis">{{item.name}}</text><view class="product-price-box"><text class="price">{{"¥"+item.price}}</text></view></view></view></block></view></view></view><view data-event-opts="{{[['tap',[['contactService',['$event']]]]]}}" class="float-service" bindtap="__e"><text class="float-icon">🎧</text><text class="float-text">联系客服</text></view><block wx:if="{{showToast}}"><view class="toast-container"><view class="toast-content"><icon type="success" size="24"></icon><text>已加入购物车</text></view></view></block></view>