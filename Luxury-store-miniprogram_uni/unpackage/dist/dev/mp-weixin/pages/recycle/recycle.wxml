<view class="recycle-container"><view class="banner-section"><image class="banner-img" src="{{cfg.banner}}" mode="aspectFill"></image><block wx:if="{{$root.g0}}"><swiper class="ticker-bar" vertical="{{true}}" autoplay="{{true}}" circular="{{true}}" interval="{{3000}}" duration="{{500}}"><block wx:for="{{cfg.tickers}}" wx:for-item="item" wx:for-index="index" wx:key="index"><swiper-item><view class="ticker-row"><text class="ticker-text">{{item.text}}</text><text class="ticker-date">{{item.date}}</text></view></swiper-item></block></swiper></block></view><view class="team-section"><text class="block-title">专业服务团队</text><view class="team-grid"><block wx:for="{{cfg.team}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="team-item"><text class="team-icon">{{item.icon}}</text><text class="team-title">{{item.title}}</text><text class="team-desc">{{item.desc}}</text></view></block></view></view><view data-event-opts="{{[['tap',[['openContact',['$event']]]]]}}" class="qrcode-section" bindtap="__e"><view class="qrcode-box"><block wx:if="{{qrcode}}"><image class="qrcode-img" src="{{qrcode}}" mode="aspectFit" show-menu-by-longpress="{{true}}"></image></block><block wx:else><image class="qrcode-img" src="/static/images/icons/service.png" mode="aspectFit"></image></block></view><view class="qrcode-info"><text class="qrcode-title">{{cfg.guardian.title}}</text><text class="qrcode-desc">{{cfg.guardian.desc}}</text></view></view><view class="flow-section"><view class="flow-tabs"><text class="{{['flow-tab '+(flowTab==='recycle'?'active':'')]}}" data-tab="recycle" data-event-opts="{{[['tap',[['switchFlow',['$event']]]]]}}" bindtap="__e">回收流程</text><text class="{{['flow-tab '+(flowTab==='consign'?'active':'')]}}" data-tab="consign" data-event-opts="{{[['tap',[['switchFlow',['$event']]]]]}}" bindtap="__e">寄售流程</text></view><view class="flow-steps"><block wx:for="{{currentSteps}}" wx:for-item="step" wx:for-index="index" wx:key="index"><view class="flow-step"><view class="flow-dot">{{index+1}}</view><text class="flow-step-name">{{step}}</text><block wx:if="{{index<$root.g1-1}}"><view class="flow-line"></view></block></view></block></view></view><block wx:if="{{cfg.guaranteeText}}"><view class="guarantee-section"><text class="block-title">85折兜底服务</text><text class="guarantee-text">{{cfg.guaranteeText}}</text></view></block><block wx:if="{{$root.g2}}"><view class="faq-section"><text class="block-title">回收服务指南</text><block wx:for="{{cfg.faqs}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="faq-item" data-index="{{index}}" data-event-opts="{{[['tap',[['toggleFaq',['$event']]]]]}}" bindtap="__e"><view class="faq-q"><text class="faq-q-mark">Q</text><text class="faq-q-text">{{item.q}}</text><text class="faq-arrow">{{openFaq===index?'−':'+'}}</text></view><block wx:if="{{openFaq===index}}"><text class="faq-a">{{item.a}}</text></block></view></block></view></block><block wx:if="{{$root.g3}}"><view class="review-section"><text class="block-title">回收用户评价</text><block wx:for="{{cfg.reviews}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="review-item"><view class="review-head"><text class="review-name">{{item.name}}</text><text class="review-region">{{item.region}}</text></view><text class="review-content">{{item.content}}</text></view></block></view></block><view data-event-opts="{{[['tap',[['openContact',['$event']]]]]}}" class="contact-btn" bindtap="__e"><text>联系回收管家</text></view><block wx:if="{{showContact}}"><view data-event-opts="{{[['tap',[['closeContact',['$event']]]]]}}" class="contact-mask" bindtap="__e"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="contact-popup" catchtap="__e"><view data-event-opts="{{[['tap',[['closeContact',['$event']]]]]}}" class="popup-close" bindtap="__e">×</view><text class="popup-title">联系回收管家</text><text class="popup-sub">长按二维码添加管家 · 评估回收价更高</text><view class="popup-qr-box"><block wx:if="{{qrcode}}"><image class="popup-qr" src="{{qrcode}}" mode="aspectFit" show-menu-by-longpress="{{true}}"></image></block><block wx:else><view class="popup-qr-empty"><text class="popup-qr-empty-icon">🎧</text><text class="popup-qr-empty-text">暂未配置二维码</text></view></block></view><view class="popup-phone-row"><text class="popup-phone-label">回收热线</text><text class="popup-phone-num">{{servicePhone}}</text></view><view data-event-opts="{{[['tap',[['callPhone',['$event']]]]]}}" class="popup-call-btn" bindtap="__e">拨打电话</view></view></view></block></view>