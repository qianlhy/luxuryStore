<view class="address-container"><block wx:if="{{isLoading}}"><loading-state vue-id="43a30cf4-1" bind:__l="__l"></loading-state></block><block wx:else><block wx:if="{{isEmpty}}"><view class="empty-address"><empty-state vue-id="43a30cf4-2" icon="address" text="暂无收货地址" sub-text="添加地址，购物更省心" bind:__l="__l"></empty-state></view></block><block wx:else><view class="address-list"><block wx:for="{{addressList}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="address-item" data-id="{{item.id}}" data-event-opts="{{[['tap',[['selectAddress',['$event']]]]]}}" bindtap="__e"><view class="address-info"><view class="name-phone"><text class="name">{{item.name}}</text><text class="phone">{{item.phone}}</text><block wx:if="{{item.isDefault}}"><text class="default-tag">默认</text></block></view><view class="address-detail">{{item.province+item.city+item.district+item.address}}</view></view><view class="address-actions"><block wx:if="{{!item.isDefault}}"><view class="action-btn" data-id="{{item.id}}" data-event-opts="{{[['tap',[['setDefault',['$event']]]]]}}" catchtap="__e"><text class="btn-text">设为默认</text></view></block><view class="action-btn" data-id="{{item.id}}" data-event-opts="{{[['tap',[['editAddress',['$event']]]]]}}" catchtap="__e"><image class="action-icon" src="/static/images/icons/edit.png"></image><text class="btn-text">编辑</text></view><view class="action-btn" data-id="{{item.id}}" data-event-opts="{{[['tap',[['deleteAddress',['$event']]]]]}}" catchtap="__e"><image class="action-icon" src="/static/images/icons/delete.png"></image><text class="btn-text">删除</text></view></view></view></block></view></block></block><view class="footer"><button data-event-opts="{{[['tap',[['addAddress',['$event']]]]]}}" class="add-address-btn" bindtap="__e">+ 新增收货地址</button></view></view>