<view class="address-edit-container"><view class="form-container"><view class="form-item"><view class="form-label">收货人</view><input class="form-input" placeholder="请输入收货人姓名" data-event-opts="{{[['input',[['inputName',['$event']]]]]}}" value="{{name}}" bindinput="__e"/></view><view class="form-item"><view class="form-label">手机号码</view><input class="form-input" type="number" placeholder="请输入手机号码" maxlength="11" data-event-opts="{{[['input',[['inputPhone',['$event']]]]]}}" value="{{phone}}" bindinput="__e"/></view><view class="form-item"><view class="form-label">所在地区</view><region-picker class="region-picker" vue-id="1d5fd308-1" value="{{region}}" data-event-opts="{{[['^change',[['bindRegionChange']]]]}}" bind:change="__e" bind:__l="__l" vue-slots="{{['default']}}"><view class="picker-content"><block wx:if="{{region[0]&&region[1]&&region[2]}}"><text>{{region[0]+" "+region[1]+" "+region[2]}}</text></block><block wx:else><text class="placeholder">请选择所在地区</text></block><text class="arrow">></text></view></region-picker></view><view class="form-item"><view class="form-label">详细地址</view><textarea class="form-textarea" placeholder="请输入详细地址，如街道、门牌号、小区、楼栋号、单元室等" data-event-opts="{{[['input',[['inputAddress',['$event']]]]]}}" value="{{address}}" bindinput="__e"></textarea></view><view data-event-opts="{{[['tap',[['toggleDefault',['$event']]]]]}}" class="form-item default-item" bindtap="__e"><view class="form-label">设为默认地址</view><view class="switch-box"><view class="{{['switch '+(isDefault?'on':'off')]}}"><view class="switch-handle"></view></view></view></view></view><view class="footer"><button class="{{['save-btn '+(isLoading?'loading':'')]}}" disabled="{{isLoading}}" data-event-opts="{{[['tap',[['saveAddress',['$event']]]]]}}" bindtap="__e">{{''+(isLoading?'保存中...':'保存')+''}}</button></view></view>