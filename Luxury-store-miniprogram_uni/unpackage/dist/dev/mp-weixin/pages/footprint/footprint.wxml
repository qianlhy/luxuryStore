<view class="footprint-container"><block wx:if="{{loading}}"><loading-state vue-id="23af6840-1" bind:__l="__l"></loading-state></block><block wx:else><block wx:if="{{$root.g0===0}}"><empty-state vue-id="23af6840-2" text="暂无浏览足迹" sub-text="快去挑选心仪好物吧" bind:__l="__l"></empty-state></block><block wx:else><block><block wx:for="{{list}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="foot-item" data-id="{{item.productId}}" data-event-opts="{{[['tap',[['goDetail',['$event']]]]]}}" bindtap="__e"><image class="foot-img" src="{{item.image}}" mode="aspectFill" lazy-load="{{true}}"></image><view class="foot-info"><text class="foot-name">{{item.name}}</text><text class="foot-price">{{"¥"+item.price}}</text><text class="foot-time">{{item.browseTime}}</text></view><view class="foot-delete" data-id="{{item.productId}}" data-event-opts="{{[['tap',[['removeItem',['$event']]]]]}}" catchtap="__e">删除</view></view></block></block></block></block></view>