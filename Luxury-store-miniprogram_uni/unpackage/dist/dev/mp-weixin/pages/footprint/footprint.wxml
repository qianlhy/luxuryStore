<view class="footprint-container"><block wx:if="{{$root.g0===0}}"><view class="empty"><text>暂无浏览足迹</text></view></block><block wx:for="{{list}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="foot-item" data-id="{{item.productId}}" data-event-opts="{{[['tap',[['goDetail',['$event']]]]]}}" bindtap="__e"><image class="foot-img" src="{{item.image}}" mode="aspectFill"></image><view class="foot-info"><text class="foot-name">{{item.name}}</text><text class="foot-price">{{"¥"+item.price}}</text><text class="foot-time">{{item.browseTime}}</text></view><view class="foot-delete" data-id="{{item.productId}}" data-event-opts="{{[['tap',[['removeItem',['$event']]]]]}}" catchtap="__e">删除</view></view></block></view>