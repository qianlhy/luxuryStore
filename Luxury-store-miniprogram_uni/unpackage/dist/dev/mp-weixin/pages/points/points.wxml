<view class="points-container"><view class="points-header"><text class="points-label">当前积分</text><text class="points-value">{{balance}}</text><text class="points-tip">下单获赠积分，积分兑换更优惠</text></view><view class="points-list"><view class="list-title">积分明细</view><block wx:if="{{$root.g0===0}}"><view class="empty"><text>暂无积分记录</text></view></block><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="log-item"><view class="log-left"><text class="log-remark">{{item.m0}}</text><text class="log-time">{{item.$orig.createTime}}</text></view><text class="{{['log-points '+(item.$orig.points>0?'plus':'minus')]}}">{{''+(item.$orig.points>0?'+':'')+item.$orig.points+''}}</text></view></block></view></view>