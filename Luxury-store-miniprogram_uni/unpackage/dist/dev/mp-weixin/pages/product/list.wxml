<view class="list-page"><block wx:if="{{loading}}"><loading-state vue-id="504effa2-1" skeleton="{{true}}" count="{{4}}" bind:__l="__l"></loading-state></block><block wx:else><block wx:if="{{loadError}}"><view class="error-box"><empty-state vue-id="504effa2-2" text="加载失败" sub-text="网络似乎开小差了" bind:__l="__l" vue-slots="{{['default']}}"><button data-event-opts="{{[['tap',[['loadData',['$event']]]]]}}" class="retry-btn" bindtap="__e">点击重试</button></empty-state></view></block><block wx:else><block wx:if="{{!$root.g0}}"><view class="empty-box"><empty-state vue-id="504effa2-3" text="暂无商品" sub-text="敬请期待更多好物" bind:__l="__l"></empty-state></view></block><block wx:else><view class="grid"><block wx:for="{{products}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="card" data-id="{{item.id}}" data-event-opts="{{[['tap',[['onTapProduct',['$event']]]]]}}" bindtap="__e"><image class="card-img" src="{{item.image}}" mode="aspectFill" lazy-load="{{true}}"></image><view class="card-info"><text class="card-name text-ellipsis">{{item.name}}</text><text class="card-price">{{"¥"+item.price}}</text></view></view></block></view></block></block></block></view>