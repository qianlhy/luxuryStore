<view><block wx:if="{{!isLoading}}"><view class="container"><swiper class="product-swiper" indicator-dots="{{true}}" autoplay="{{false}}" interval="3000" duration="500" circular="{{true}}" data-event-opts="{{[['change',[['onSwiperChange',['$event']]]]]}}" bindchange="__e"><block wx:for="{{product.images}}" wx:for-item="item" wx:for-index="index" wx:key="index"><swiper-item><image class="product-image" src="{{item}}" mode="aspectFill"></image></swiper-item></block></swiper><view class="page-indicator"><text>{{current+1+"/"+$root.g0}}</text></view><view class="product-info card"><view class="product-price-box"><text class="price">{{"¥"+product.price}}</text><text class="price-original">{{"¥"+product.originalPrice}}</text></view><view class="product-title">{{product.name}}</view><view class="product-desc">{{product.description}}</view><view class="product-stats"><text class="stat-item">{{"销量 "+product.sales}}</text><text class="stat-item">{{"库存 "+product.inventory}}</text><text class="stat-item">{{"评分 "+product.rating}}</text></view></view><view class="card"><view class="flex-between"><text class="section-title">购买数量</text><view class="counter"><view data-event-opts="{{[['tap',[['decreaseCount',['$event']]]]]}}" class="{{['counter-btn '+(count<=1?'disabled':'')]}}" bindtap="__e">-</view><view class="counter-num">{{count}}</view><view data-event-opts="{{[['tap',[['increaseCount',['$event']]]]]}}" class="{{['counter-btn '+(count>=product.inventory?'disabled':'')]}}" bindtap="__e">+</view></view></view></view><view class="card"><view class="card-header"><text class="section-title">商品详情</text></view><view class="card-body"><view class="product-detail">{{product.detail}}</view></view></view><view class="card"><view class="card-header"><text class="section-title">猜你喜欢</text></view><view class="related-products grid grid-2"></view></view></view></block><block wx:if="{{isLoading}}"><view class="loading-container"><view class="loading"><image class="loading-icon" src="/static/images/icons/loading.png" mode="aspectFit"></image><text>加载中...</text></view></view></block><view class="footer"><view class="footer-left"><view data-event-opts="{{[['tap',[['showMoreActions',['$event']]]]]}}" class="footer-icon-btn" bindtap="__e"><image class="footer-icon" src="/static/images/icons/more.png"></image><text>更多</text></view><view data-event-opts="{{[['tap',[['contactService',['$event']]]]]}}" class="footer-icon-btn" bindtap="__e"><image class="footer-icon" src="/static/images/icons/service.png"></image><text>客服</text></view><navigator class="footer-icon-btn" url="/pages/cart/cart" open-type="switchTab"><image class="footer-icon" src="/static/images/icons/cart.png"></image><text>购物车</text><block wx:if="{{$root.g1>0}}"><view class="cart-badge">{{$root.g2}}</view></block></navigator></view><view class="footer-right"><view data-event-opts="{{[['tap',[['addToCart',['$event']]]]]}}" class="add-cart-btn" bindtap="__e">加入购物车</view><view data-event-opts="{{[['tap',[['buyNow',['$event']]]]]}}" class="buy-now-btn" bindtap="__e">立即购买</view></view></view><block wx:if="{{isAddedToCart}}"><view class="toast-container"><view class="toast-content"><icon type="success" size="24"></icon><text>已加入购物车</text></view></view></block><block wx:if="{{showActionSheet}}"><view data-event-opts="{{[['tap',[['closeActionSheet',['$event']]]]]}}" class="action-sheet-mask" bindtap="__e"></view></block><view class="{{['action-sheet '+(showActionSheet?'show':'')]}}"><view class="action-sheet-header"><text>更多操作</text><view data-event-opts="{{[['tap',[['closeActionSheet',['$event']]]]]}}" class="action-sheet-close" bindtap="__e">×</view></view><view class="action-sheet-body"><view data-event-opts="{{[['tap',[['collectProduct',['$event']]]]]}}" class="action-item" bindtap="__e"><image class="action-icon" src="/static/images/icons/collect.png"></image><text>收藏商品</text></view><view data-event-opts="{{[['tap',[['shareProduct',['$event']]]]]}}" class="action-item" bindtap="__e"><image class="action-icon" src="/static/images/icons/share.png"></image><text>分享商品</text></view><button class="action-item share-btn" open-type="share"><image class="action-icon" src="/static/images/icons/share.png"></image><text>分享给朋友</text></button></view></view></view>