<view><block wx:if="{{!isLoading}}"><view class="container"><swiper class="product-swiper" indicator-dots="{{true}}" autoplay="{{false}}" interval="3000" duration="500" circular="{{true}}" data-event-opts="{{[['change',[['onSwiperChange',['$event']]]]]}}" bindchange="__e"><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="index" wx:key="index"><swiper-item><image class="product-image" src="{{item.m0}}" mode="aspectFill"></image></swiper-item></block></swiper><view class="page-indicator"><text>{{current+1+"/"+$root.g0}}</text></view><view class="product-info card"><view class="product-price-box"><text class="price">{{"¥"+product.price}}</text><text class="price-original">{{"¥"+product.originalPrice}}</text></view><view class="product-title">{{product.name}}</view><view class="product-desc">{{product.description}}</view><view class="product-stats"><text class="stat-item">{{"销量 "+product.sales}}</text><text class="stat-item">{{"库存 "+product.inventory}}</text><text class="stat-item">{{"评分 "+product.rating}}</text></view></view><view class="card"><view class="flex-between"><text class="section-title">购买数量</text><view class="counter"><view data-event-opts="{{[['tap',[['decreaseCount',['$event']]]]]}}" class="{{['counter-btn '+(count<=1?'disabled':'')]}}" bindtap="__e">-</view><view class="counter-num">{{count}}</view><view data-event-opts="{{[['tap',[['increaseCount',['$event']]]]]}}" class="{{['counter-btn '+(count>=product.inventory?'disabled':'')]}}" bindtap="__e">+</view></view></view></view><view class="card"><view class="card-header"><text class="section-title">商品详情</text></view><view class="card-body"><view class="product-detail">{{product.detail}}</view></view></view><view class="card"><view class="card-header"><text class="section-title">猜你喜欢</text></view><view class="related-products grid grid-2"></view></view></view></block><block wx:if="{{isLoading}}"><view class="loading-container"><loading-state vue-id="778f76c8-1" bind:__l="__l"></loading-state></view></block><view class="footer"><view class="footer-left"><view data-event-opts="{{[['tap',[['contactService',['$event']]]]]}}" class="footer-icon-btn" bindtap="__e"><image class="footer-icon" src="/static/images/icons/service.png"></image><text>客服</text></view><navigator class="footer-icon-btn" url="/pages/cart/cart" open-type="switchTab"><image class="footer-icon" src="/static/images/icons/cart.png"></image><text>购物车</text></navigator></view><view class="footer-right"><view data-event-opts="{{[['tap',[['addToCart',['$event']]]]]}}" class="add-cart-btn" bindtap="__e">加入购物车</view><view data-event-opts="{{[['tap',[['contactSales',['$event']]]]]}}" class="contact-sales-btn" bindtap="__e">下单请联系您的微信销售</view></view></view><block wx:if="{{isAddedToCart}}"><view class="toast-container"><view class="toast-content"><icon type="success" size="24"></icon><text>已加入购物车</text></view></view></block></view>