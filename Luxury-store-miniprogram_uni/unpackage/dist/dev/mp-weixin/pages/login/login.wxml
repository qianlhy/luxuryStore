<view class="login-container"><view class="login-header"><image class="logo" src="https://img1.baidu.com/it/u=3937158862,3439944525&fm=253&app=138&f=JPEG?w=800&h=1067" mode="aspectFit"></image><text class="title">欢迎来到名品汇商城</text></view><view class="login-form"><view class="form-item"><view class="input-label">手机号</view><input class="input" type="number" placeholder="请输入手机号" maxlength="11" data-event-opts="{{[['input',[['inputPhone',['$event']]]]]}}" value="{{phone}}" bindinput="__e"/></view><view class="form-item"><view class="input-label">{{isPasswordLogin?'密码':'验证码'}}</view><view class="input-wrapper"><input class="{{['input '+(!isPasswordLogin?'input-with-btn':'')]}}" type="{{isPasswordLogin?'password':'number'}}" placeholder="{{isPasswordLogin?'请输入密码':'请输入验证码'}}" maxlength="{{isPasswordLogin?'20':'6'}}" data-event-opts="{{[['input',[['inputPassword',['$event']]]]]}}" value="{{password}}" bindinput="__e"/><block wx:if="{{!isPasswordLogin}}"><view data-event-opts="{{[['tap',[['getVerifyCode',['$event']]]]]}}" class="{{['verify-code-btn '+(countdown>0?'disabled':'')]}}" catchtap="__e">{{''+(countdown>0?countdown+'s':'获取验证码')+''}}</view></block></view></view><view data-event-opts="{{[['tap',[['switchLoginType',['$event']]]]]}}" class="login-type-switch" bindtap="__e"><text>{{isPasswordLogin?'验证码登录':'密码登录'}}</text></view><view class="agreement"><view data-event-opts="{{[['tap',[['toggleAgree',['$event']]]]]}}" class="{{['checkbox '+(isAgree?'checked':'')]}}" bindtap="__e"></view><text class="agreement-text">我已阅读并同意</text><text data-event-opts="{{[['tap',[['goToUserAgreement',['$event']]]]]}}" class="agreement-link" bindtap="__e">《用户协议》</text><text class="agreement-text">和</text><text data-event-opts="{{[['tap',[['goToPrivacyPolicy',['$event']]]]]}}" class="agreement-link" bindtap="__e">《隐私政策》</text></view><button class="{{['login-btn '+(isLoading?'loading':'')]}}" disabled="{{isLoading}}" data-event-opts="{{[['tap',[['passwordLogin',['$event']]]]]}}" bindtap="__e">{{''+(isLoading?'登录中...':'登 录')+''}}</button><button class="{{['wx-login-btn '+(isLoading?'loading':'')]}}" disabled="{{isLoading}}" data-event-opts="{{[['tap',[['wxLogin',['$event']]]]]}}" bindtap="__e"><image class="wx-icon" src="/static/images/icons/wechat.png" mode="aspectFit"></image> 微信一键登录 </button></view></view>