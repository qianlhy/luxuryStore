<view class="category-page"><view class="search-bar"><view data-event-opts="{{[['tap',[['goSearch',['$event']]]]]}}" class="search-box" bindtap="__e"><text class="search-icon">🔍</text><text class="search-placeholder">请搜索您想要的商品</text></view></view><view class="category-container"><view class="category-sidebar"><scroll-view class="sidebar-scroll" scroll-y="{{true}}"><block wx:for="{{categories}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="{{['category-item '+(currentCategory&&currentCategory.id===item.id?'active':'')]}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['switchCategory',['$event']]]]]}}" bindtap="__e">{{item.name}}</view></block></scroll-view></view><view class="category-content"><block wx:if="{{$root.g0>0}}"><scroll-view class="sub-tabs" scroll-x="{{true}}"><block wx:for="{{subCategories}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="{{['sub-tab '+(currentSubCategory===item.id?'active':'')]}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['switchSubCategory',['$event']]]]]}}" bindtap="__e">{{item.name}}</view></block></scroll-view></block><scroll-view class="product-scroll" scroll-y="{{true}}"><block wx:if="{{$root.g1===0}}"><view class="no-data"><text>暂无商品</text></view></block><block wx:for="{{products}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="product-item" data-id="{{item.id}}" data-event-opts="{{[['tap',[['onTapProduct',['$event']]]]]}}" bindtap="__e"><image class="product-image" src="{{item.image}}" mode="aspectFill"></image><view class="product-info"><text class="product-name">{{item.name}}</text><text class="product-price">{{"¥"+item.price}}</text></view></view></block></scroll-view></view></view><view class="float-bar"><view data-event-opts="{{[['tap',[['goCart',['$event']]]]]}}" class="float-cart" bindtap="__e"><text class="cart-emoji">🛒</text></view><text class="float-total">{{"总计: ¥"+cartTotal}}</text><view data-event-opts="{{[['tap',[['shareCart',['$event']]]]]}}" class="float-share" bindtap="__e">分享</view></view></view>