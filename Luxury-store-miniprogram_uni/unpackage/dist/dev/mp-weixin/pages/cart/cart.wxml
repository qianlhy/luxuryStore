<view class="cart-container"><block wx:if="{{!isLogin}}"><view class="empty-cart"><empty-state vue-id="1775f8c0-1" icon="cart" text="登录后查看购物车" sub-text="同步多端购物车，方便快捷" bind:__l="__l" vue-slots="{{['default']}}"><button data-event-opts="{{[['tap',[['goToLogin',['$event']]]]]}}" class="go-shopping-btn" bindtap="__e">去登录</button></empty-state></view></block><block wx:else><block wx:if="{{isLoading}}"><loading-state vue-id="1775f8c0-2" bind:__l="__l"></loading-state></block><block wx:else><block wx:if="{{isEmpty}}"><view class="empty-cart"><empty-state vue-id="1775f8c0-3" icon="cart" text="购物车还是空的" bind:__l="__l" vue-slots="{{['default']}}"><button data-event-opts="{{[['tap',[['goToShopping',['$event']]]]]}}" class="go-shopping-btn" bindtap="__e">去逛逛</button></empty-state></view></block><block wx:else><block><block wx:if="{{invalidCount>0}}"><view class="invalid-tip"><text>{{invalidCount+"件商品已失效，将自动归类"}}</text></view></block><view class="cart-list"><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="{{['cart-item '+(item.$orig.invalid?'invalid-item':'')]}}"><view class="select-box" data-index="{{index}}" data-event-opts="{{[['tap',[['toggleSelect',['$event']]]]]}}" bindtap="__e"><view class="{{['select-icon '+(item.$orig.selected&&!item.$orig.invalid?'selected':'')]}}"></view></view><image class="product-image" src="{{item.m0}}" mode="aspectFill"></image><view class="product-info"><text class="product-name text-ellipsis">{{item.$orig.name}}</text><block wx:if="{{item.$orig.invalid}}"><text class="invalid-label">{{item.$orig.invalidReason}}</text></block><view class="product-price-box"><text class="price">{{"¥"+item.$orig.price}}</text></view><view class="product-action"><view class="counter"><view class="{{['counter-btn '+(item.$orig.count<=1?'disabled':'')]}}" data-id="{{item.$orig.id}}" data-count="{{item.$orig.count}}" data-event-opts="{{[['tap',[['decreaseCount',['$event']]]]]}}" bindtap="__e">-</view><view class="counter-num">{{item.$orig.count}}</view><view class="{{['counter-btn '+(item.$orig.count>=item.$orig.inventory?'disabled':'')]}}" data-id="{{item.$orig.id}}" data-count="{{item.$orig.count}}" data-inventory="{{item.$orig.inventory}}" data-event-opts="{{[['tap',[['increaseCount',['$event']]]]]}}" bindtap="__e"> + </view></view><view class="delete-btn" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['deleteItem',['$event']]]]]}}" bindtap="__e"><image class="delete-icon" src="/static/images/icons/delete.png"></image></view></view></view></view></block></view><view class="cart-footer"><view data-event-opts="{{[['tap',[['toggleSelectAll',['$event']]]]]}}" class="select-all" bindtap="__e"><view class="{{['select-icon '+(isAllSelected?'selected':'')]}}"></view><text>全选</text></view><view class="cart-total"><view class="total-price"><text class="price-label">合计：</text><text class="price">{{"¥"+totalPrice}}</text></view><text class="price-desc">不含运费</text></view><button data-event-opts="{{[['tap',[['shareToSales',['$event']]]]]}}" class="share-sales-btn" bindtap="__e">{{"分享给销售("+totalCount+")"}}</button></view></block></block></block></block></view>